{
  "name": "pure-blanche-guestbook",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker + D1 backend for the Pure Blanche guestbook",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute pure-blanche-guestbook --remote --file=./schema.sql",
    "db:init:local": "wrangler d1 execute pure-blanche-guestbook --local --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.90.0"
  }
}
